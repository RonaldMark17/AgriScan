# Copy to /etc/nginx/sites-available/agriscan and update the certificate paths.
# This host-level Nginx sits in front of the Docker-published ports:
#   frontend: 127.0.0.1:5173 -> container port 80
#   backend:  127.0.0.1:8000 -> container port 8000

server {
  listen 80;
  listen [::]:80;
  server_name agriscann.duckdns.org;

  return 301 https://$host$request_uri;
}

server {
  listen 443 ssl http2;
  listen [::]:443 ssl http2;
  server_name agriscann.duckdns.org;

  ssl_certificate /etc/letsencrypt/live/agriscann.duckdns.org/fullchain.pem;
  ssl_certificate_key /etc/letsencrypt/live/agriscann.duckdns.org/privkey.pem;

  # The app enforces a 10 MB photo limit; Nginx allows the multipart envelope around it.
  client_max_body_size 11m;

  proxy_set_header Host $host;
  proxy_set_header X-Real-IP $remote_addr;
  proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
  proxy_set_header X-Forwarded-Host $host;
  proxy_set_header X-Forwarded-Proto $scheme;

  location /api/ {
    proxy_pass http://127.0.0.1:8000;
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
  }

  location /uploads/ {
    proxy_pass http://127.0.0.1:8000;
  }

  location = /health {
    proxy_pass http://127.0.0.1:8000;
  }

  location /assets/ {
    proxy_pass http://127.0.0.1:5173;
  }

  location /icons/ {
    proxy_pass http://127.0.0.1:5173;
  }

  location = /manifest.webmanifest {
    proxy_pass http://127.0.0.1:5173;
  }

  location = /sw.js {
    proxy_pass http://127.0.0.1:5173;
  }

  location = /offline.html {
    proxy_pass http://127.0.0.1:5173;
  }

  location / {
    proxy_pass http://127.0.0.1:5173;
  }
}
